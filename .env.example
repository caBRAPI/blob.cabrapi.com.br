# Server
PORT=3000
HOST=0.0.0.0

# Local persistence
DATABASE_URL=file:./data/blob.db
STORAGE_PATH=data/blob-storage

# Security
TOKEN_SECRET=change-me-with-32-characters-or-more
# Used as admin token for protected operations (upload/delete/private list)

# Signed URL behavior
SIGNED_URL_TTL_MIN_SECONDS=30
SIGNED_URL_TTL_MAX_SECONDS=900

# Rate limiting
SIGN_RATE_LIMIT_MAX=20
SIGN_RATE_LIMIT_WINDOW_MS=60000
DOWNLOAD_RATE_LIMIT_MAX=120
DOWNLOAD_RATE_LIMIT_WINDOW_MS=60000

# Optional hardening
# ALLOWED_MIME_TYPES=image/png,image/jpeg,application/pdf
# MAX_UPLOAD_SIZE_BYTES=20971520
# CORS_ORIGINS=https://app.example.com

# Optional: default expiration for private blobs (ISO 8601 ou segundos)
#BLOB_DEFAULT_EXPIRES_AT=
